{
  "name": "manda-backoffice",
  "version": "0.0.1",
  "private": true,
  "description": "Manda staff backoffice — Electron desktop app",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev --noSandbox",
