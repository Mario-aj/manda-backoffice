    "react-router-dom": "^7.9.6"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "electron": "^39.2.4",
    "electron-vite": "^4.0.0",
    "openapi-typescript": "^7.8.0",
    "typescript": "^5.7.3",
    "vite": "^7.2.4",
